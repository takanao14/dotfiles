{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "timezone": "Asia/Tokyo",
  "minimumReleaseAge": "1 day",
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true,
      "platformAutomerge": false,
      "ignoreTests": true
    },
    {
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "description": "kubectl is pinned to a minor (pkgs.k8s.io repo paths are per-minor); collapse stable releases to major.minor so patch releases never rewrite the pin",
      "matchDepNames": ["kubernetes/kubernetes"],
      "extractVersion": "^v?(?<version>\\d+\\.\\d+)\\.\\d+$"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["(^|/)\\.chezmoiscripts/.*\\.sh(\\.tmpl)?$"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[^\\s]+) depName=(?<depName>[^\\s]+)\\nreadonly \\w+=\"\\$\\{\\w+:-(?<currentValue>[^}]+)\\}\""
      ],
      "extractVersionTemplate": "^v?(?<version>.+)$",
      "versioningTemplate": "semver-coerced"
    }
  ]
}
