# Added by OrbStack: 'orb' SSH host for Linux machines
# This only works if it's at the top of ssh_config (before any Host blocks).
# This won't be added again if you remove it.
Include ~/.orbstack/ssh/config

Host *
{{- if .has1password }}
     IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
{{- end }}
{{- if eq .chezmoi.os "linux" }}
     # Load the key into the running agent on first use, so the passphrase
     # is typed once per agent lifetime instead of per connection.
     AddKeysToAgent yes
{{- end }}
     SetEnv TERM=xterm-256color

# ForwardAgent is intentionally not set here for Host * (forwarding the agent
# to every host, including untrusted ones, lets a compromised remote root
# authenticate elsewhere as you). Enable it per trusted host instead, e.g. in
# ~/.ssh/config.d/*.conf:
#   Host trusted-host
#       ForwardAgent yes
#ForwardX11 yes

Include ~/.ssh/config.d/*.conf
