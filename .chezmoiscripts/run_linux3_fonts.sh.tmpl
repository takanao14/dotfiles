#!/bin/bash

# {{- if eq .chezmoi.os "linux" }}

# Font installation script for Linux (Ubuntu 24.04 / Rocky 9.x)

set -euo pipefail

# Constants
readonly UDEV_GOTHIC_VERSION="v2.2.0"
readonly FONTS_DIR="$HOME/.local/share/fonts/udev-gothic"
readonly DOWNLOAD_URL="https://github.com/yuru7/udev-gothic/releases/download/${UDEV_GOTHIC_VERSION}/UDEVGothic_NF_${UDEV_GOTHIC_VERSION}.zip"

# Color output
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly NC='\033[0m'

log_info() {
    echo -e "${GREEN}[INFO]${NC} $*"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $*"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $*"
}

check_system() {
    log_info "Checking system requirements..."
    
    # Check if GUI session is available (xrdp or Wayland)
    local has_gui=false
    
    # Check for xrdp
    if systemctl is-active --quiet xrdp 2>/dev/null; then
        log_info "xrdp service detected"
        has_gui=true
    fi
    
    # Check for Wayland compositor processes
    if pgrep -E "^(weston|sway|wayfire|labwc|river|hyprland)$" >/dev/null 2>&1; then
        log_info "Wayland compositor detected"
        has_gui=true
    fi
    
    if [[ "$has_gui" == "false" ]]; then
        log_warn "No GUI session detected (xrdp or Wayland required)"
        log_warn "Skipping font installation"
        exit 0
    fi
}

check_dependencies() {
    local missing_deps=()
    
    for cmd in curl unzip fc-cache fc-list; do
        if ! command -v "$cmd" &> /dev/null; then
            missing_deps+=("$cmd")
        fi
    done
    
    if [[ ${#missing_deps[@]} -gt 0 ]]; then
        log_error "Missing required dependencies: ${missing_deps[*]}"
        # {{- if eq .chezmoi.osRelease.id "ubuntu" }}
        log_info "Install them with: sudo apt-get install -y fontconfig unzip curl"
        # {{- else if eq .chezmoi.osRelease.id "rocky" }}
        log_info "Install them with: sudo dnf install -y fontconfig unzip curl"
        # {{- end }}
        return 1
    fi
    
    return 0
}

is_font_installed() {
    fc-list : family | grep -q "UDEV Gothic NF"
}

download_and_extract_font() {
    local tmp_dir="$1"
    local zip_file="$tmp_dir/udev-gothic.zip"
    
    log_info "Downloading UDEV Gothic 35 ${UDEV_GOTHIC_VERSION}..."
    if ! curl -fsSL --retry 3 --retry-delay 2 "$DOWNLOAD_URL" -o "$zip_file"; then
        log_error "Failed to download UDEV Gothic 35"
        return 1
    fi
    
    log_info "Extracting fonts..."
    if ! unzip -q "$zip_file" -d "$tmp_dir"; then
        log_error "Failed to extract font archive"
        return 1
    fi
    
    return 0
}

install_font_files() {
    local tmp_dir="$1"
    
    log_info "Installing font files to ${FONTS_DIR}..."
    mkdir -p "$FONTS_DIR"
    
    # Find and copy all font files
    if ! find "$tmp_dir" -type f \( -name "*.ttf" -o -name "*.otf" \) -exec cp {} "$FONTS_DIR/" \;; then
        log_error "Failed to copy font files"
        return 1
    fi
    
    return 0
}

rebuild_font_cache() {
    log_info "Rebuilding font cache..."
    if ! fc-cache -f "$FONTS_DIR"; then
        log_warn "Failed to rebuild font cache"
        return 1
    fi
    
    return 0
}

install_udev_gothic() {
    log_info "Installing UDEV Gothic 35 font..."
    
    if is_font_installed; then
        log_info "UDEV Gothic 35 is already installed"
        return 0
    fi
    
    if ! check_dependencies; then
        return 1
    fi
    
    local tmp_dir
    tmp_dir="$(mktemp -d)"
    
    # Ensure cleanup on exit
    trap "rm -rf '$tmp_dir'" RETURN
    
    if ! download_and_extract_font "$tmp_dir"; then
        return 1
    fi
    
    if ! install_font_files "$tmp_dir"; then
        return 1
    fi
    
    if ! rebuild_font_cache; then
        return 1
    fi
    
    log_info "UDEV Gothic 35 installed successfully"
    return 0
}

main() {
    log_info "=== Font Installation Script ==="
    
    check_system
    
    if ! install_udev_gothic; then
        log_error "Font installation failed"
        exit 1
    fi
    
    log_info "=== Font installation completed ==="
}

main "$@"

# {{- end }}
