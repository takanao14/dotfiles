#!/usr/bin/env zsh

# Brewfile hash: {{ include "dot_Brewfile" | sha256sum }}

[[ "$(uname)" == "Darwin" ]] || exit 0

echo "macos script"

if ! command -v brew &> /dev/null; then
  echo "Homebrew is not installed; skipping brew bundle"
  exit 0
fi

brew bundle --global

# helm plugins aren't expressible in a Brewfile; install helm-diff the same way
# run_onchange_linux1_tool.sh does for Linux. --verify=false because helm v4
# verifies plugin provenance by default and the git source doesn't support it.
if command -v helm &> /dev/null && ! helm plugin list 2>/dev/null | grep -q "^diff"; then
  echo "Installing helm-diff plugin..."
  helm plugin install --verify=false https://github.com/databus23/helm-diff
fi
