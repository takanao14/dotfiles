#!/usr/bin/env bash
# Linux development tools installation script

# {{- if eq .chezmoi.os "linux" }}

set -euo pipefail

# Color output
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly NC='\033[0m'

log_info() {
    echo -e "${GREEN}[INFO]${NC} $*"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $*"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $*"
}

readonly BIN_DIR="$HOME/.local/bin"

# Version variables
readonly FZF_VERSION="${FZF_VERSION:-0.68.0}"
readonly ZELLIJ_VERSION="${ZELLIJ_VERSION:-0.43.1}"
readonly KUBIE_VERSION="${KUBIE_VERSION:-0.26.1}"
readonly K9S_VERSION="${K9S_VERSION:-0.50.18}"
readonly HELMFILE_VERSION="${HELMFILE_VERSION:-1.3.0}"
readonly K0SCTL_VERSION="${K0SCTL_VERSION:-0.28.0}"

# Ensure bin directory exists
mkdir -p "$BIN_DIR"

# Helper function to install binary from GitHub releases
install_binary() {
    local name="$1"
    local url="$2"
    local output_file="$3"

    log_info "Installing ${name}..."
    local tmp_dir
    tmp_dir=$(mktemp -d)
    trap "rm -rf ${tmp_dir}" RETURN

    if [[ "$url" == *.tar.gz ]]; then
        curl -fsSL "$url" | tar xz -C "$tmp_dir"
        install -m 0755 "$tmp_dir/${name}" "$output_file" || \
            install -m 0755 "$tmp_dir/${name##*/}" "$output_file"
    else
        curl -fsSL "$url" -o "$output_file"
        chmod 0755 "$output_file"
    fi
}

# Helper function to update package cache
update_package_cache() {
    # {{- if eq .chezmoi.osRelease.id "ubuntu" }}
    sudo apt-get update
    # {{- else if eq .chezmoi.osRelease.id "rocky" }}
    sudo dnf makecache --refresh
    # {{- end }}
}

# Helper function to install packages
install_packages() {
    # {{- if eq .chezmoi.osRelease.id "ubuntu" }}
    sudo apt-get install -y "$@"
    # {{- else if eq .chezmoi.osRelease.id "rocky" }}
    sudo dnf install -y "$@"
    # {{- end }}
}

# Helper function to add APT repository with GPG key (Ubuntu)
add_apt_repository() {
    local repo_name="$1"
    local gpg_url="$2"
    local repo_line="$3"
    local keyring_path="/usr/share/keyrings/${repo_name}-keyring.gpg"

    log_info "Adding ${repo_name} repository..."
    curl -fsSL "$gpg_url" | gpg --dearmor | sudo tee "$keyring_path" > /dev/null
    sudo chmod 644 "$keyring_path"
    echo "$repo_line" | sudo tee "/etc/apt/sources.list.d/${repo_name}.list" > /dev/null
    sudo chmod 644 "/etc/apt/sources.list.d/${repo_name}.list"
}

# Helper function to add DNF repository (Rocky)
add_dnf_repository() {
    local repo_name="$1"
    local repo_url="$2"
    local gpgkey_url="$3"

    log_info "Adding ${repo_name} repository..."
    sudo tee "/etc/yum.repos.d/${repo_name}.repo" > /dev/null <<EOF
[${repo_name}]
name=${repo_name}
baseurl=${repo_url}
enabled=1
gpgcheck=1
gpgkey=${gpgkey_url}
EOF
}

# Helper function to check and install tools
ensure_installed() {
    local cmd="$1"
    local install_func="$2"

    if ! command -v "$cmd" &> /dev/null; then
        "$install_func"
    fi
}

# ============================================================================
# Shell Enhancement Tools
# ============================================================================

install_sheldon() {
    log_info "Installing sheldon..."
    curl --proto '=https' -fsSL https://rossmacarthur.github.io/install/crate.sh \
        | bash -s -- --repo rossmacarthur/sheldon --to "$BIN_DIR"
}

install_starship() {
    log_info "Installing starship..."
    curl -fsSL https://starship.rs/install.sh | sh -s -- --bin-dir "$BIN_DIR" -y
}

install_direnv() {
    log_info "Installing direnv..."
    export bin_path="$BIN_DIR"
    curl -fsSL https://direnv.net/install.sh | bash
}

install_eza() {
    install_binary "eza" \
        "https://github.com/eza-community/eza/releases/latest/download/eza_x86_64-unknown-linux-gnu.tar.gz" \
        "$BIN_DIR/eza"
}

install_fzf() {
    install_binary "fzf" \
        "https://github.com/junegunn/fzf/releases/download/v${FZF_VERSION}/fzf-${FZF_VERSION}-linux_amd64.tar.gz" \
        "$BIN_DIR/fzf"
}

install_zellij() {
    install_binary "zellij" \
        "https://github.com/zellij-org/zellij/releases/download/v${ZELLIJ_VERSION}/zellij-x86_64-unknown-linux-musl.tar.gz" \
        "$BIN_DIR/zellij"
}

# ============================================================================
# HashiCorp Tools
# ============================================================================

install_hashicorp_tools() {
    log_info "Installing HashiCorp tools (Terraform, Packer, Vault)..."

    # Install prerequisites
    update_package_cache
    install_packages gnupg software-properties-common

    # Source os-release to get the codename
    . /etc/os-release
    local codename="${UBUNTU_CODENAME:-$(lsb_release -cs)}"

    add_apt_repository "hashicorp" \
        "https://apt.releases.hashicorp.com/gpg" \
        "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/hashicorp-keyring.gpg] https://apt.releases.hashicorp.com ${codename} main"
    {{- else if eq .chezmoi.osRelease.id "rocky" }}
    add_dnf_repository "hashicorp" "https://rpm.releases.hashicorp.com/RHEL/\$releasever/\$basearch/stable"
    {{- end }}

    update_package_cache
    install_packages terraform packer vault
}

install_terragrunt() {
    log_info "Installing terragrunt..."
    curl -fsSL https://terragrunt.gruntwork.io/install | bash -s -- -d "$BIN_DIR"
}

# ============================================================================
# Kubernetes Tools
# ============================================================================

install_kubectl() {
    log_info "Installing kubectl..."
    # Reference: https://kubernetes.io/docs/tasks/tools/install-kubectl-linux/#install-using-native-package-management

    update_package_cache
    install_packages ca-certificates curl gnupg

    {{- if eq .chezmoi.osRelease.id "ubuntu" }}
    sudo apt-get install -y apt-transport-https
    sudo mkdir -p -m 755 /etc/apt/keyrings
    add_apt_repository "kubernetes" \
        "https://pkgs.k8s.io/core:/stable:/v1.35/deb/Release.key" \
        "deb [signed-by=/usr/share/keyrings/kubernetes-keyring.gpg] https://pkgs.k8s.io/core:/stable:/v1.35/deb/ /"
    {{- else if eq .chezmoi.osRelease.id "rocky" }}
    add_dnf_repository "kubernetes" \
        "https://pkgs.k8s.io/core:/stable:/v1.35/rpm/" \
        "https://pkgs.k8s.io/core:/stable:/v1.35/rpm/repodata/repomd.xml.key"
    {{- end }}

    update_package_cache
    install_packages kubectl
}

install_helm() {
    log_info "Installing helm..."
    # Reference: https://helm.sh/docs/intro/install/

    {{- if eq .chezmoi.osRelease.id "ubuntu" }}
    add_apt_repository "helm" \
        "https://packages.buildkite.com/helm-linux/helm-debian/gpgkey" \
        "deb [signed-by=/usr/share/keyrings/helm-keyring.gpg] https://packages.buildkite.com/helm-linux/helm-debian/any/ any main"

    {{- else if eq .chezmoi.osRelease.id "rocky" }}

    {{- end }}

    update_package_cache
    install_packages helm
}

install_kubie() {
    install_binary "kubie" \
        "https://github.com/sbstp/kubie/releases/download/v${KUBIE_VERSION}/kubie-linux-amd64" \
        "$BIN_DIR/kubie"
}

install_k9s() {
    install_binary "k9s" \
        "https://github.com/derailed/k9s/releases/download/v${K9S_VERSION}/k9s_Linux_amd64.tar.gz" \
        "$BIN_DIR/k9s"
}

install_helmfile() {
    install_binary "helmfile" \
        "https://github.com/helmfile/helmfile/releases/download/v${HELMFILE_VERSION}/helmfile_${HELMFILE_VERSION}_linux_amd64.tar.gz" \
        "$BIN_DIR/helmfile"
}

install_k0sctl() {
    install_binary "k0sctl" \
        "https://github.com/k0sproject/k0sctl/releases/download/v${K0SCTL_VERSION}/k0sctl-linux-amd64" \
        "$BIN_DIR/k0sctl"
}

# ============================================================================
# Main Installation
# ============================================================================

main() {
    log_info "=== Linux Development Tools Installation ==="

    # Shell enhancement tools
    ensure_installed "sheldon" install_sheldon
    ensure_installed "starship" install_starship
    ensure_installed "direnv" install_direnv
    ensure_installed "eza" install_eza
    ensure_installed "fzf" install_fzf
    ensure_installed "zellij" install_zellij

    # HashiCorp tools
    ensure_installed "terraform" install_hashicorp_tools
    ensure_installed "terragrunt" install_terragrunt

    # Kubernetes tools
    ensure_installed "kubectl" install_kubectl
    ensure_installed "helm" install_helm
    ensure_installed "kubie" install_kubie
    ensure_installed "k9s" install_k9s
    ensure_installed "helmfile" install_helmfile
    ensure_installed "k0sctl" install_k0sctl

    log_info "=== Installation completed ==="
}

main

# {{- end }}
