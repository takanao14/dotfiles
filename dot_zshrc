# zshrc

if [[ ":$PATH:" != *":$HOME/.local/bin:"* ]]; then
  export PATH="$HOME/.local/bin:$PATH"
fi

if [[ -f "$HOME/.env" ]]; then
  _load_dotenv() {
    setopt local_options allexport
    source "$HOME/.env"
  }
  _load_dotenv
  unfunction _load_dotenv
fi

if command -v sheldon &> /dev/null; then
  eval "$(sheldon source)"
fi
